{
  "additional-repositories": ["multilib"],
  "archinstall-language": "English",
  "audio_config": {
    "audio": "pipewire"
  },
  "bootloader_config": {
    "bootloader": "Systemd-boot",
    "uki": false,
    "removable": false
  },
  "debug": false,
  "disk_config": {
    "config_type": "manual_partitioning",
    "device_modifications": [
      {
        "device": "/dev/nvme0n1",
        "wipe": true,
        "partitions": [
          {
            "btrfs": [],
            "flags": ["boot"],
            "fs_type": "fat32",
            "length": {"sector_size": null, "total_size": null, "unit": "GiB", "value": 1},
            "mount_options": [],
            "mountpoint": "/boot",
            "obj_id": "efi-part",
            "start": {"sector_size": {"sector_size": null, "total_size": null, "unit": "B", "value": 512}, "total_size": null, "unit": "sectors", "value": 34},
            "status": "create",
            "type": "primary"
          },
          {
            "btrfs": [],
            "flags": [],
            "fs_type": "swap",
            "length": {"sector_size": null, "total_size": null, "unit": "GiB", "value": 16},
            "mount_options": [],
            "mountpoint": "swap",
            "obj_id": "swap-part",
            "start": {"sector_size": {"sector_size": null, "total_size": null, "unit": "B", "value": 512}, "total_size": null, "unit": "MiB", "value": 1050},
            "status": "create",
            "type": "primary"
          },
          {
            "btrfs": [],
            "flags": [],
            "fs_type": "ext4",
            "length": {"sector_size": null, "total_size": null, "unit": "%", "value": 100},
            "mount_options": [],
            "mountpoint": "/",
            "obj_id": "root-part",
            "start": {"sector_size": {"sector_size": null, "total_size": null, "unit": "B", "value": 512}, "total_size": null, "unit": "MiB", "value": 17434},
            "status": "create",
            "type": "primary"
          }
        ]
      }
    ]
  },
  "disk_encryption": null,
  "hostname": "aribook",
  "kernels": ["linux"],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  },
  "mirror_config": {
    "mirror_regions": {
      "Netherlands": [
        "https://mirror.nl.leaseweb.net/archlinux/$repo/os/$arch",
        "https://mirrors.xtom.nl/archlinux/$repo/os/$arch",
        "https://ftp.nluug.nl/os/Linux/distr/archlinux/$repo/os/$arch"
      ],
      "Germany": [
        "https://ftp.fau.de/archlinux/$repo/os/$arch",
        "https://ftp.halifax.rwth-aachen.de/archlinux/$repo/os/$arch",
        "https://mirror.fra10.de.leaseweb.net/archlinux/$repo/os/$arch"
      ],
      "Belgium": [
        "https://mirror.1ago.be/archlinux/$repo/os/$arch"
      ],
      "Denmark": [
        "https://mirrors.dotsrc.org/archlinux/$repo/os/$arch",
        "https://mirror.group.one/archlinux/$repo/os/$arch"
      ],
      "Sweden": [
        "https://mirror.bahnhof.net/pub/archlinux/$repo/os/$arch",
        "https://ftp.lysator.liu.se/pub/archlinux/$repo/os/$arch",
        "https://mirror.accum.se/mirror/archlinux/$repo/os/$arch"
      ],
      "Finland": [
        "https://mirror.5i.fi/archlinux/$repo/os/$arch",
        "https://mirror.srv.fail/archlinux/$repo/os/$arch"
      ]
    }
  },
  "network_config": {
