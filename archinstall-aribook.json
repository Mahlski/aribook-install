    "git",
    "gvfs",
    "intel-ucode",
    "linux",
    "linux-firmware",
    "linux-headers",
    "man-db",
    "man-pages",
    "nano",
    "nano-syntax-highlighting",
    "neovim",
    "networkmanager",
    "ntfs-3g",
    "sof-firmware",
    "stow",
    "sudo",
    "tree",
    "ttf-jetbrains-mono-nerd",
    "xdg-user-dirs"
  ],
  "parallel_downloads": 5,
  "profile_config": null,
  "script": "guided",
  "silent": false,
  "swap": false,
  "timezone": "Europe/Amsterdam"
